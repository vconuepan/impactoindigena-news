{
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/fonts/*",
      "headers": {
        "Cache-Control": "public, max-age=2592000"
      }
    },
    {
      "route": "/stories/*",
      "rewrite": "/api/og/story-html"
    },
    {
      "route": "/sitemap.xml",
      "rewrite": "/api/sitemap.xml"
    },
    {
      "route": "/sitemap-news.xml",
      "rewrite": "/api/sitemap-news.xml"
    },
    {
      "route": "/feed",
      "rewrite": "/api/feed"
    },
    {
      "route": "/podcast/feed.xml",
      "rewrite": "/api/podcast/feed.xml"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/images/*",
      "/*.png",
      "/*.ico",
      "/*.xml",
      "/*.txt"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN"
  }
}