# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (with pgvector extension installed)
DATABASE_URL=postgresql://user:password@localhost:5432/impactoindigena_news

# OpenAI API key for LLM analysis and image generation
OPENAI_API_KEY=sk-...

# URL of the frontend (used for CORS)
FRONTEND_URL=http://localhost:5173

# Random secret for signing JWT auth tokens (32+ characters)
JWT_SECRET=change-me-to-a-long-random-string

# ─── Server ───────────────────────────────────────────────────────────────────

# Set to "production" on Render (enables secure cross-origin cookies)
NODE_ENV=development

# Port the backend listens on (Render sets this automatically)
PORT=3001

# Site canonical URL (used in RSS feeds, sitemaps, social posts)
SITE_URL=https://impactoindigena.news

# ─── LLM Provider (optional — defaults to OpenAI) ────────────────────────────

# Switch provider: "openai" (default) | "openrouter" | "azure"
# LLM_PROVIDER=openai

# OpenRouter (if LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=sk-or-...

# Azure OpenAI (if LLM_PROVIDER=azure)
# AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_API_VERSION=2025-01-01-preview
# AZURE_OPENAI_DEPLOYMENT_SMALL=gpt-4o-mini
# AZURE_OPENAI_DEPLOYMENT_MEDIUM=gpt-4o-mini
# AZURE_OPENAI_DEPLOYMENT_LARGE=gpt-4o
# AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-small
# AZURE_OPENAI_DEPLOYMENT_TTS=tts-1-hd
# AZURE_OPENAI_DEPLOYMENT_DALLE=dall-e-3

# Override default model names (only for openai/openrouter providers)
# OPENAI_MODEL_SMALL=gpt-5.4-mini
# OPENAI_MODEL_MEDIUM=gpt-5.4-mini
# OPENAI_MODEL_LARGE=gpt-5.4

# ─── Image Generation (optional — separate Azure resource) ───────────────────
# Required for AI-generated story images on Instagram and Twitter posts.
# Uses "Sweden Central" region that supports gpt-image-2.
# AZURE_IMAGE_ENDPOINT=https://my-image-resource.openai.azure.com
# AZURE_IMAGE_API_KEY=...
# AZURE_IMAGE_API_VERSION=2025-04-01-preview
# AZURE_IMAGE_DEPLOYMENT=gpt-image-2
# AZURE_IMAGE_QUALITY=high

# ─── Cloudflare R2 (optional — enables Instagram carousel posts) ──────────────
# Without R2, Instagram posts fall back to single-image format.
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=impacto-indigena-media
# R2_PUBLIC_URL=https://media.impactoindigena.news

# ─── Content Extraction APIs (optional — one is required for full extraction) ─

# Diffbot (default extraction API)
# DIFFBOT_API_KEY=...
# EXTRACTION_API=diffbot

# Pipfeed (alternative extraction API)
# PIPFEED_API_KEY=...

# ─── Newsletter — Brevo (optional) ───────────────────────────────────────────
# BREVO_API_KEY=...
# BREVO_FROM_EMAIL=noticias@impactoindigena.news
# BREVO_FROM_NAME=Impacto Indígena
# BREVO_TEST_SEGMENT_ID=...

# ─── Social Media — Bluesky (optional) ───────────────────────────────────────
# BLUESKY_HANDLE=impactoindigena.bsky.social
# BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# BLUESKY_AUTO_POST_ENABLED=false
# BLUESKY_LOOKBACK_HOURS=25

# ─── Social Media — Mastodon (optional) ──────────────────────────────────────
# MASTODON_URL=https://mastodon.social
# MASTODON_TOKEN=...
# MASTODON_AUTO_POST_ENABLED=false
# MASTODON_VISIBILITY=unlisted

# ─── Social Media — Instagram (optional) ─────────────────────────────────────
# Long-lived Graph API token. Expires after 60 days — requires manual renewal.
# See .context/instagram.md for setup details.
# INSTAGRAM_ACCESS_TOKEN=...
# INSTAGRAM_USER_ID=...
# INSTAGRAM_AUTO_POST_ENABLED=false

# ─── Social Media — Twitter / X (optional) ───────────────────────────────────
# TWITTER_API_KEY=...
# TWITTER_API_SECRET=...
# TWITTER_ACCESS_TOKEN=...
# TWITTER_ACCESS_TOKEN_SECRET=...
# TWITTER_AUTO_POST_ENABLED=false

# ─── Social Media — LinkedIn (optional) ──────────────────────────────────────
# LINKEDIN_ACCESS_TOKEN=...
# LINKEDIN_AUTHOR_URN=urn:li:person:...
# LINKEDIN_AUTO_POST_ENABLED=false

# ─── Podcast (optional) ───────────────────────────────────────────────────────
# PODCAST_AUTO_GENERATE_ENABLED=false
# PODCAST_VOICE=nova

# ─── Tuning (optional — safe to leave at defaults) ───────────────────────────
# LOG_LEVEL=info
# RSS_ITEM_LIMIT=30
# SELECT_RATIO=0.5
# SELECT_RELEVANCE_MIN=5
# NEWSLETTER_STORIES_PER_ISSUE=4
# DEDUP_ENABLED=true
