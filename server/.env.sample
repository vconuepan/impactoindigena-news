# To generate links, e.g. to confirm newsletter subscriptions
API_URL="https://vocesindigenas-backend.onrender.com"

# Site URL for links in posts
SITE_URL="https://impactoindigena.news"

# Frontend URL for CORS
FRONTEND_URL="https://impactoindigena.news"
# Server port (optional, defaults to 3001 locally, Render sets automatically)
PORT=3001
JWT_SECRET=[at least 32 characters]
# PUBLIC_API_KEY=optional-api-key-for-public-access-of-protected-routes

# Database (PostgreSQL with pgvector)
DATABASE_URL="postgresql://user:password@localhost:5432/actually_relevant?schema=public"

# LLM Provider (azure | openai | openrouter — defaults to openai if unset)
LLM_PROVIDER=azure

# Azure OpenAI (used when LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_SMALL=gpt-4.1-mini
AZURE_OPENAI_DEPLOYMENT_MEDIUM=gpt-4.1-mini
AZURE_OPENAI_DEPLOYMENT_LARGE=gpt-4o
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-small
AZURE_OPENAI_DEPLOYMENT_TTS=tts-1-hd
AZURE_OPENAI_DEPLOYMENT_DALLE=dall-e-3

# OpenAI direct (used when LLM_PROVIDER=openai, or for DALL-E if Azure quota unavailable)
# OPENAI_API_KEY="sk-..."

# Services
DIFFBOT_TOKEN=your_token_here
PIPFEED_API_KEY=

# R2 Storage (Cloudflare) — for generated images and podcast audio
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=impacto-indigena-media
R2_PUBLIC_URL=https://your-public-r2-domain.com

BREVO_API_KEY=xkeysib-...
BREVO_FROM_EMAIL=your@domain.com
BREVO_FROM_NAME=Your Publication
BREVO_TEST_SEGMENT_ID=

BLUESKY_AUTO_POST_ENABLED=true
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=

MASTODON_AUTO_POST_ENABLED=true
MASTODON_URL=https://mastodon.social
MASTODON_TOKEN=""